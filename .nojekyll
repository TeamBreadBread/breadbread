<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>빵빵 Docs</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="//cdn.jsdelivr.net/npm/docsify/themes/vue.css">
</head>
<body>
  <div id="app"></div>
  <script>
    window.$docsify = {
      name: '빵빵 Docs',
      repo: 'https://github.com/TeamBreadBread/breadbread',
      loadSidebar: true,
      subMaxLevel: 2,
      auto2top: true,
    }
  </script>
  <script src="//cdn.jsdelivr.net/npm/docsify/lib/docsify.min.js"></script>
</body>
</html>