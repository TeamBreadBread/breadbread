{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/@(sw.js|registerSW.js|firebase-messaging-sw.js|manifest.webmanifest)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/auth/kakao/callback",
        "destination": "/index.html"
      },
      {
        "source": "/auth/naver/callback",
        "destination": "/index.html"
      },
      {
        "source": "/auth/google/callback",
        "destination": "/index.html"
      },
      {
        "source": "/auth/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/bakeries/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/reservations/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/posts/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/users/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/notifications/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/courses/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/payments/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/images/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
