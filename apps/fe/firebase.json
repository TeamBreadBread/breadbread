{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/auth/kakao/callback",
        "destination": "/index.html"
      },
      {
        "source": "/auth/naver/callback",
        "destination": "/index.html"
      },
      {
        "source": "/auth/google/callback",
        "destination": "/index.html"
      },
      {
        "source": "/auth/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/bakeries/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/reservations/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/posts/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/users/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/notifications/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/courses/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/payments/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/images/**",
        "run": {
          "serviceId": "bread-be",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
