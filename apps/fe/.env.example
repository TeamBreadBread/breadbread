# apps/fe 환경 변수 예시 (이 파일은 커밋해도 됩니다. 실제 키는 넣지 마세요.)
# 로컬 개발: 아래를 복사해 `.env.local` 로 저장한 뒤 값을 채우세요.
#   cp .env.example .env.local
#
# 변경 후 `pnpm dev` 를 다시 시작해야 Vite가 읽습니다.

# --- 카카오 로그인 (필수: REST API 키) ---
# 카카오 개발자 콘솔 → 내 애플리케이션 → 앱 키 → REST API 키
# (JavaScript 키가 아닌 REST API 키 입니다)
# Redirect URI 등록 (카카오 콘솔 + 백엔드 허용 목록과 동일해야 함):
#   http://localhost:3000/auth/kakao/callback  (로컬, Vite 기본 포트)
#   https://www.breadbread.io/auth/kakao/callback (운영)
#   https://breadbread.pages.dev/auth/kakao/callback (Pages 미리보기)
# 로컬 개발 시 VITE_FRONT_BASE_URL 은 비우세요 (설정 시 redirect URI가 콘솔과 어긋납니다).
# Cloud Run Secret Manager: KAKAO_CLIENT_ID = 아래 REST API 키와 동일, KAKAO_CLIENT_SECRET = 콘솔 Client Secret
VITE_KAKAO_REST_API_KEY=

# --- 네이버 로그인 (네이버 개발자 센터 Client ID) ---
# Redirect URI: http://localhost:3000/auth/naver/callback , https://www.breadbread.io/auth/naver/callback
VITE_NAVER_CLIENT_ID=

# --- 구글 로그인 (Google Cloud OAuth Client ID) ---
# Redirect URI: http://localhost:3000/auth/google/callback , https://www.breadbread.io/auth/google/callback
VITE_GOOGLE_CLIENT_ID=

# --- 카카오맵 (JavaScript 키, REST API 키와 별도) ---
# 카카오 개발자 콘솔 → 앱 키 → JavaScript 키
# 플랫폼에 http://localhost:3000 , https://www.breadbread.io 등록
VITE_KAKAO_MAP_KEY=

# 출발지 키워드 검색(/preference)은 REST API 키로 카카오 로컬 API를 호출합니다.
# (REST 키 없으면 JavaScript 키 + maps services 로 폴백)
# AI 코스 지도 보행 경로: 카카오모빌리티 보행 길찾기 API (별도 이용 신청 필요)
#   https://developers.kakaomobility.com — 미승인·운영 CORS 시 직선으로 표시됩니다.

# --- API / 프론트 URL (선택) ---
# VITE_API_BASE_URL=https://api.breadbread.io
# VITE_FRONT_BASE_URL=http://localhost:3000

# --- 포트원 결제 (선택) ---
# VITE_PORTONE_STORE_ID=
# VITE_PORTONE_CHANNEL_KEY=

# --- 개발용 (선택) ---
# VITE_ENABLE_DEVTOOLS=true
# VITE_DEV_FALLBACK_COURSE_ID=
# VITE_USE_BOARD_MOCK=
