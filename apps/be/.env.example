# ========================
# Database
# ========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=breaddb
DB_USERNAME=bread
DB_PASSWORD=bread1234
DB_MAX_POOL_SIZE=5
DB_MIN_IDLE=1
DB_CONNECTION_TIMEOUT=3000

# ========================
# Server / Spring
# ========================
SPRING_PROFILES_ACTIVE=local
PORT=8000

# ========================
# JWT
# ========================
JWT_SECRET=your-access-secret-key-minimum-32-characters-here
JWT_EXPIRES_IN=3600
JWT_REFRESH_SECRET=your-refresh-secret-key-minimum-32-characters-here
JWT_REFRESH_EXPIRES_IN=604800

# ========================
# Redis
# ========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=3s

# ========================
# OAuth2 - Google
# ========================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ========================
# OAuth2 - Naver
# ========================
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ========================
# OAuth2 - Kakao
# ========================
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# ========================
# SMS (CoolSMS)
# ========================
COOLSMS_API_KEY=your-coolsms-api-key
COOLSMS_API_SECRET=your-coolsms-api-secret
COOLSMS_SENDER=01012345678

# 인증번호 유효시간(초) / 토큰 유효시간(초)
PHONE_CODE_EXPIRES_IN=300
PHONE_TOKEN_EXPIRES_IN=600

# ========================
# Google Cloud Platform
# ========================
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=your-gcs-bucket-name

# ========================
# PortOne (결제)
# ========================
PORTONE_API_BASE_URL=https://api.portone.io
PORTONE_API_SECRET=your-portone-api-secret
PORTONE_STORE_ID=your-portone-store-id
PORTONE_CHANNEL_KEY=your-portone-channel-key
PORTONE_WEBHOOK_SECRET=your-portone-webhook-secret

# ========================
# AI 코스 추천
# ========================
AI_COURSE_WEBHOOK_URL=your-ai-course-webhook-url
AI_CHAT_WEBHOOK_URL=your-ai-chat-webhook-url
AI_CONGESTION_WEBHOOK_URL=your-ai-congestion-webhook-url
AI_WEBHOOK_TIMEOUT_SECONDS=90
AI_JOB_TTL_HOURS=24
AI_API_KEY=your-ai-api-key

# ========================
# Kakao Mobility / Route
# ========================
KAKAO_MOBILITY_APP_KEY=your-kakao-mobility-app-key
KAKAO_MOBILITY_TIMEOUT_SECONDS=10
ROUTE_PROVIDER=kakao

# ========================
# Naver Maps
# ========================
NAVER_MAPS_CLIENT_ID=your-naver-maps-client-id
NAVER_MAPS_CLIENT_SECRET=your-naver-maps-client-secret
NAVER_MAPS_TIMEOUT_SECONDS=10

# ========================
# Google Places
# ========================
GOOGLE_PLACES_API_KEY=your-google-places-api-key
GOOGLE_PLACES_PHOTO_URL_TTL_SECONDS=345600

# ========================
# 로컬 전용 (선택)
# ========================
# GCS 서비스 계정 키 파일 경로 (로컬에서 GCS 실제 호출 시 필요)
GCP_CREDENTIALS_PATH=classpath:key.json
# JPA 쿼리 로그 출력 여부
SHOW_SQL=false
