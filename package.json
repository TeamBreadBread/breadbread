{
  "name": "breadbread",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "prepare": "husky",
    "build": "pnpm --filter fe build",
    "lint:fe": "pnpm --filter fe lint",
    "lint:be": "pnpm --filter bread-be lint",
    "format:fe": "pnpm --filter fe format",
    "format:be": "pnpm --filter bread-be format",
    "typecheck:fe": "pnpm --filter fe exec tsc -b",
    "typecheck:be": "pnpm --filter bread-be exec tsc --noEmit",
    "typecheck:shared": "pnpm --filter @breadbread/shared typecheck"
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "apps/fe/src/**/*.{ts,tsx}": [
      "\"C:\\Program Files\\nodejs\\node.exe\" ./node_modules/eslint/bin/eslint.js --fix",
      "\"C:\\Program Files\\nodejs\\node.exe\" ./node_modules/prettier/bin/prettier.cjs --write"
    ],
    "apps/be/src/**/*.ts": [
      "\"C:\\Program Files\\nodejs\\node.exe\" ./node_modules/eslint/bin/eslint.js --fix",
      "\"C:\\Program Files\\nodejs\\node.exe\" ./node_modules/prettier/bin/prettier.cjs --write"
    ],
    "packages/shared/src/**/*.ts": [
      "\"C:\\Program Files\\nodejs\\node.exe\" ./node_modules/eslint/bin/eslint.js --fix",
      "\"C:\\Program Files\\nodejs\\node.exe\" ./node_modules/prettier/bin/prettier.cjs --write"
    ]
  }
}
